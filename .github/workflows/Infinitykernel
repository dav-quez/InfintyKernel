name: Build InfinityKernel One UI 8 (C2S)

on:
  workflow_dispatch:
    inputs:
      device:
        description: 'Device (c2s or c2slte)'
        required: true
        default: 'c2s'

jobs:
  build:
    runs-on: ubuntu-latest
    timeout-minutes: 120

    steps:
      - name: Checkout InfinityKernel
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Add Artisan remote
        run: |
          git remote add artisan https://github.com/Android-Artisan/android_kernel_samsung_exynos990.git
          git fetch artisan sixteen

      - name: Add RAGNARØK remote
        run: |
          git remote add ragnarok https://github.com/dav-quez/CyberInfintyKernel.git
          git fetch ragnarok RAGNARØK

      - name: Analyze differences
        run: |
          echo "[*] Changed files between Artisan (base) and RAGNARØK (optimizations):"
          git diff --name-only artisan/sixteen..ragnarok/RAGNARØK > changed_files.txt
          cat changed_files.txt
          
          echo ""
          echo "[*] Generating detailed diff..."
          git diff artisan/sixteen..ragnarok/RAGNARØK > ragnarok_changes.patch
          
          # Count changes by directory
          echo ""
          echo "[*] Changes by directory:"
          git diff --name-only artisan/sixteen..ragnarok/RAGNARØK | cut -d/ -f1-2 | sort | uniq -c

      - name: Upload analysis artifacts
        uses: actions/upload-artifact@v4
        with:
          name: Analysis-Files
          path: |
            changed_files.txt
            ragnarok_changes.patch

      - name: Install dependencies
        run: |
          sudo apt-get update
          sudo apt-get install -y \
            build-essential \
            libarchive-tools \
            ccache \
            wget \
            git \
            gcc-aarch64-linux-gnu \
            device-tree-compiler \
            libssl-dev \
            libelf-dev

      - name: Setup base (Artisan One UI 8)
        run: |
          echo "[*] Checking out Artisan One UI 8 base..."
          git checkout artisan/sixteen
          
          echo "[*] Kernel version:"
          head -5 Makefile

      - name: Apply SAFE patches from RAGNARØK
        run: |
          echo "[*] Applying safe optimizations from RAGNARØK..."
          
          # Cherry-pick SAFE changes (overclock, thermal, undervolting)
          # These files are safe to port:
          SAFE_FILES=(
            "drivers/cpufreq/exynos-acme.c"
            "drivers/cpufreq/exynos-acme.h"
            "drivers/thermal/"
            "drivers/gpu/arm/bv_r38p1/platform/"
          )
          
          # Extract only SAFE file changes from patch
          for file in "${SAFE_FILES[@]}"; do
            if git diff artisan/sixteen..ragnarok/RAGNARØK -- "$file" | grep -q "^diff"; then
              echo "[+] Applying patch for $file"
              git show ragnarok/RAGNARØK:"$file" > "$file" 2>/dev/null || true
            fi
          done
          
          git add -A
          git commit -m "Apply RAGNARØK performance optimizations (safe)" || true

      - name: Configure kernel for C2S
        run: |
          cd $GITHUB_WORKSPACE
          
          # Get defconfig for C2S
          if [ ! -f arch/arm64/configs/c2s_defconfig ]; then
            echo "[-] c2s_defconfig not found, using c2slte"
            cp arch/arm64/configs/c2slte_defconfig arch/arm64/configs/c2s_defconfig || true
          fi
          
          # Make oldconfig
          make ARCH=arm64 CROSS_COMPILE=aarch64-linux-gnu- c2s_defconfig
          make ARCH=arm64 CROSS_COMPILE=aarch64-linux-gnu- oldconfig < /dev/null

      - name: Compile kernel
        run: |
          cd $GITHUB_WORKSPACE
          
          export ARCH=arm64
          export CROSS_COMPILE=aarch64-linux-gnu-
          export CCACHE_DIR=$HOME/.ccache
          
          echo "[*] Starting kernel compilation..."
          make -j$(nproc) Image dtbs
          
          if [ -f arch/arm64/boot/Image ]; then
            echo "[+] Kernel compiled successfully!"
            ls -lh arch/arm64/boot/Image
          else
            echo "[-] Kernel compilation failed!"
            exit 1
          fi

      - name: Create flashable ZIP
        run: |
          cd $GITHUB_WORKSPACE
          
          mkdir -p out/boot
          cp arch/arm64/boot/Image out/boot/kernel
          
          # Create simple flashable structure
          mkdir -p flashable/{boot,META-INF/com/google/android}
          cp arch/arm64/boot/Image flashable/boot/
          
          # Create updater-script
          cat > flashable/META-INF/com/google/android/updater-script << 'EOF'
          ui_print("Installing InfinityKernel One UI 8...");
          package_extract_dir("boot", "/tmp/boot");
          write_raw_image(package_extract_file("boot/Image"), "boot");
          ui_print("InfinityKernel installed!");
          EOF
          
          cd flashable
          zip -r ../InfinityKernel-One-UI-8-C2S.zip *
          
          ls -lh ../InfinityKernel-One-UI-8-C2S.zip

      - name: Upload kernel
        uses: actions/upload-artifact@v4
        with:
          name: InfinityKernel-C2S
          path: |
            ${{ github.workspace }}/InfinityKernel-One-UI-8-C2S.zip
            ${{ github.workspace }}/arch/arm64/boot/Image

      - name: Summary
        run: |
          echo "=========================================="
          echo "✅ InfinityKernel Build Summary"
          echo "=========================================="
          echo "Device: C2S (Note 20 Ultra Exynos)"
          echo "ROM: Artisan 3.5.0 (One UI 8 / Android 16)"
          echo "Optimizations: RAGNARØK (safe patches)"
          echo "=========================================="
